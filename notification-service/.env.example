# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=notification-service
KAFKA_CONSUMER_GROUP=notification-service

# Email Configuration
EMAIL_ENABLED=true
EMAIL_PROVIDER=console              # Options: 'console' (development) or 'smtp' (production)

# SMTP Configuration (for production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false                   # true for 465, false for 587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@nitte-merch-shop.com

# Slack Configuration
SLACK_ENABLED=true
SLACK_WEBHOOK_URL=                    # Set to enable real Slack notifications

# Ticket / Escalation Configuration
TICKET_ENABLED=true
TICKET_PROVIDER=console               # Options: 'console' (development) or 'rest' (production)
TICKET_ENDPOINT=                      # REST endpoint for ticket creation (if provider=rest)

# Keycloak Event Handling
KEYCLOAK_ADMIN_EMAILS=internal-admin@nitte.ac.in

# Admin Notification Recipients (comma-separated)
ADMIN_NOTIFICATION_EMAILS=internal-admin@nitte.ac.in

# Service Configuration
NODE_ENV=development                 # Options: 'development', 'production'
LOG_LEVEL=info                       # Options: 'error', 'warn', 'info', 'debug'

# Verification Email URLs
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
