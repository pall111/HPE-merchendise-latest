# Force LF line endings for files that run inside Linux containers
# This prevents CRLF issues when cloning on Windows

*.sh    text eol=lf
*.bash  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.js    text eol=lf
*.java  text eol=lf
*.md    text eol=lf
*.xml   text eol=lf
*.properties text eol=lf
*.conf  text eol=lf

# Let Git handle line endings for other text files automatically
* text=auto

# Binary files should never have line ending conversion
*.jar   binary
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary
