      "emailVerified": true,
      "firstName": "Merchant",
      "lastName": "User",
      "credentials": [{ "type": "password", "value": "merchant@123", "temporary": false }],
      "realmRoles": ["merchant"]
    },
    {
      "username": "admin_user",
      "enabled": true,
      "email": "admin_user@alumni-shop.local",
