{
  "id": "nitte-realm",
  "realm": "nitte-realm",
  "displayName": "NITTE Alumni Merchandise (Alumni Shop)",
  "enabled": true,
  "loginTheme": "nitte",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 1800,
  "roles": {
    "realm": [
      { "name": "admin",              "description": "System administrator with full access" },
      { "name": "admin-internal",     "description": "Internal DevOps admin with Jenkins/Nexus/Keycloak Admin access (2FA required)" },
      { "name": "alumni",             "description": "Verified alumni user" },
      { "name": "non_alumni",         "description": "Non-alumni user with limited access" },
      { "name": "merchant",           "description": "Product merchant and seller" },
      { "name": "merchant-amazon",    "description": "Third-party merchant: Amazon" },
      { "name": "merchant-flipkart",  "description": "Third-party merchant: Flipkart" },
      { "name": "internal-user",      "description": "Internal NITTE staff with limited DevOps access (Jenkins viewer, observability read-only)" },
      { "name": "mongo_writer",       "description": "Internal service role allowed to write to MongoDB" },
      { "name": "nexus-admin",        "description": "Nexus repository administrator" },
      { "name": "nexus-developer",    "description": "Nexus repository developer (read/write)" }
    ]
  },
  "clients": [
    {
      "clientId": "nitte-client",
      "name": "NITTE Merchandise Client (alumni-backend)",
      "description": "Confidential backend client for the NITTE / Alumni Shop API",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "nitte-client-secret",
      "redirectUris": ["*"],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:5174",
        "http://localhost:3000"
      ],
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "defaultRoles": ["non_alumni"],
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "jenkins-client",
      "name": "Jenkins CI/CD Server",
      "description": "Client for Jenkins OAuth integration",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "jenkins-client-secret",
      "redirectUris": ["http://localhost:8081/*"],
      "webOrigins": ["http://localhost:8081"],
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "fullScopeAllowed": true
    },
    {
      "clientId": "observability-proxy",
      "name": "Observability Proxy",
      "description": "oauth2-proxy client for Prometheus and Jaeger",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "observability-proxy-secret",
      "redirectUris": [
        "http://localhost:9090/oauth2/callback",
        "http://localhost:16686/oauth2/callback"
      ],
      "webOrigins": ["http://localhost:9090", "http://localhost:16686"],
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": true
    },
    {
      "clientId": "grafana-client",
      "name": "Grafana Monitoring",
      "description": "Client for Grafana OAuth2 SSO",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "grafana-client-secret",
      "redirectUris": ["http://localhost:3001/*"],
      "webOrigins": ["http://localhost:3001"],
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": true
    },
    {
      "clientId": "nexus-client",
      "name": "Sonatype Nexus Repository",
      "description": "Client for Nexus OAuth integration",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "nexus-client-secret",
      "redirectUris": ["http://localhost:8082/*"],
      "webOrigins": ["http://localhost:8082"],
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "fullScopeAllowed": true
    }
  ],
  "users": [
    {
      "username": "admin@nitte.edu",
      "enabled": true,
      "email": "admin@nitte.edu",
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [{ "type": "password", "value": "admin@123",    "temporary": false }],
      "realmRoles": ["admin"]
    },
    {
