    {
      "username": "service-account-nitte-client",
      "enabled": true,
      "serviceAccountClientId": "nitte-client",
      "realmRoles": ["mongo_writer"],
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users",
          "query-users",
          "manage-realm",
          "view-realm"
        ]
      }
    },
    {
