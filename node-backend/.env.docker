# Docker Environment Configuration for Node.js Backend
NODE_ENV=production
PORT=3000
MONGODB_URL=mongodb://app_writer:app_writer_pass@mongodb:27017/nitte_merch?authSource=nitte_merch
PYTHON_SERVICE_URL=http://python-service:8000
JWT_SECRET=super-secret-key-change-in-production
JWT_EXPIRY=7d
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:8080
REQUEST_TIMEOUT=30000
KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=nitte-realm
KEYCLOAK_CLIENT_ID=nitte-client
KEYCLOAK_CLIENT_SECRET=nitte-client-secret
KAFKA_BROKERS=kafka:9092
API_BASE=http://node-backend:3000
