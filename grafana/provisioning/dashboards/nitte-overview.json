{
  "uid": "nitte-shop-overview",
  "title": "NITTE Shop — Overview",
  "tags": ["nitte", "api", "business"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "HTTP Traffic",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error Rate (5xx)",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[1m])) / sum(rate(http_requests_total[1m]))",
          "legendFormat": "5xx error rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Response Latency (p50 / p95 / p99)",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "type": "row",
      "title": "Business Metrics",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Total Orders",
      "gridPos": { "x": 0, "y": 10, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "mappings": []
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "orders_created_total",
          "legendFormat": "Orders",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "User Registrations",
      "gridPos": { "x": 6, "y": 10, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "green", "mode": "fixed" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "user_registrations_total",
          "legendFormat": "Registrations",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Products Viewed",
      "gridPos": { "x": 12, "y": 10, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "purple", "mode": "fixed" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "products_viewed_total",
          "legendFormat": "Views",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Active Connections",
      "gridPos": { "x": 18, "y": 10, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "active_connections",
          "legendFormat": "Connections",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Order Rate (orders/min)",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "blue", "mode": "fixed" } }
      },
      "targets": [
        {
          "expr": "rate(orders_created_total[5m]) * 60",
          "legendFormat": "orders/min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Auth Attempts",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "sum(rate(auth_attempts_total[1m])) by (type, success)",
          "legendFormat": "{{type}} / success={{success}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "row",
      "title": "Infrastructure",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Database Operations",
      "gridPos": { "x": 0, "y": 23, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "sum(rate(database_operations_total[1m])) by (operation, status)",
          "legendFormat": "{{operation}} ({{status}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "API Errors by Endpoint",
      "gridPos": { "x": 8, "y": 23, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "sum(rate(api_errors_total[1m])) by (endpoint, error_code)",
          "legendFormat": "{{endpoint}} ({{error_code}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Node.js Memory Usage",
      "gridPos": { "x": 16, "y": 23, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"node-backend\"}",
          "legendFormat": "RSS",
          "refId": "A"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"node-backend\"}",
          "legendFormat": "Heap Used",
          "refId": "B"
        }
      ]
    }
  ]
}
